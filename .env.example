# ---- Spotify credentials ----
# Create an app at https://developer.spotify.com/dashboard
# Copy the Client ID and Client Secret here.
#
# In the Spotify app settings, add this Redirect URI (must match exactly):
#   http://127.0.0.1:3000/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Public URL the browser uses to reach this server (used for the Spotify redirect).
# Use http://127.0.0.1:3000 for local dev. Spotify does NOT accept http://localhost
# for new apps, so 127.0.0.1 is required.
PUBLIC_URL=http://127.0.0.1:3000

# Port the server listens on.
PORT=3000
